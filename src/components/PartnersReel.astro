---
/*
 * Horizontal scrolling partners reel. Duplicated set for seamless loop —
 * the animation translates -50%, so the second half re-enters from the
 * right just as the first half exits left.
 */
import { content } from '../content';

const pass = content.partners.items;
const doubled = [...pass, ...pass];
---

<div class="reel" aria-label="Partner organisations">
  <div class="reel-track">
    {
      doubled.map((p, i) => {
        const aria = i >= pass.length ? 'true' : undefined;
        const modClass = p.modifier ? `is-${p.modifier}` : '';
        if (p.img) {
          return (
            <div class:list={['reel-item', modClass]} aria-hidden={aria}>
              <img src={p.img} alt={i >= pass.length ? '' : (p.alt ?? p.name)} />
            </div>
          );
        }
        return (
          <div class:list={['reel-item', 'text', modClass]} aria-hidden={aria}>
            {p.textLogo}
          </div>
        );
      })
    }
  </div>
</div>
