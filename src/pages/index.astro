---
import Base from '../layouts/Base.astro';
import StatsBand from '../components/StatsBand.astro';
import PartnersReel from '../components/PartnersReel.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { content } from '../content';

const {
  site,
  hero,
  whatWeDo,
  approach,
  opportunities,
  people,
  directors,
  partners,
} = content;
---

<Base title={site.title} description={site.description}>
  <span id="top"></span>

  <!-- ========== HERO (full-screen drone footage) ========== -->
  <section class="hero">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      aria-hidden="true"
    >
      <source src="/assets/Hitchin.mp4" type="video/mp4" />
    </video>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="wrap hero-inner">
      <div>
        <h1 class="hero-anim d1" set:html={hero.headline} />
        <p
          class="lead hero-anim d2"
          style="margin-top:32px;font-family:var(--serif);font-style:italic;color:var(--gold-soft);font-size:clamp(20px,1.8vw,28px);max-width:48ch;"
        >
          {hero.subheading}
        </p>
        <p class="lead hero-anim d3">{hero.body}</p>
        <div class="actions hero-anim d4">
          <a href="#contact" class="btn btn-primary">
            {hero.ctaPrimary} <span class="btn-arrow">→</span>
          </a>
          <a href="#what-we-do" class="btn btn-ghost-navy">{hero.ctaSecondary}</a>
        </div>
      </div>
    </div>
    <div class="hero-scroll" aria-hidden="true">
      <span>Scroll</span>
      <span class="line"></span>
    </div>
  </section>

  <!-- ========== TRACK RECORD ========== -->
  <StatsBand />

  <!-- ========== WHAT WE DO ========== -->
  <section class="band cream" id="what-we-do">
    <div class="wrap">
      <div class="section-head fade-up">
        <div><span class="num">{whatWeDo.number}</span></div>
        <div>
          <h2 style="margin-top:12px;">{whatWeDo.heading}</h2>
          <p style="margin-top:18px;">{whatWeDo.intro}</p>
        </div>
      </div>

      <div class="services-grid stagger">
        {
          whatWeDo.services.map((s) => (
            <article class="service">
              <span class="idx">— {s.idx}</span>
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ========== OUR APPROACH (case study) ========== -->
  {
    approach.enabled && (
      <section class="band stone" id="approach">
        <div class="wrap">
          <div class="section-head fade-up">
            <div><span class="num">{approach.number}</span></div>
            <div>
              <h2 set:html={approach.heading} />
            </div>
          </div>

          <div class="case-study-grid stagger">
            <div
              class="case-study-image"
              style="background-image:url('/assets/Hitchin sketch 1.jpg');"
              role="img"
              aria-label="Architectural sketch of the gardens at Priory Park Gardens, Hitchin"
            />
            <div class="case-study-copy">
              <h3>{approach.caseStudy.title}</h3>
              {approach.caseStudy.paragraphs.map((p) => <p>{p}</p>)}
              <div class="case-study-facts">
                {
                  approach.caseStudy.facts.map((f) => (
                    <div class="fact">
                      <div class="k">{f.key}</div>
                      <div class="v">{f.value}</div>
                    </div>
                  ))
                }
              </div>
              <div class="cta-row">
                <a
                  href={approach.caseStudy.ctaHref}
                  target="_blank"
                  rel="noopener"
                  class="btn btn-ghost-navy"
                >
                  {approach.caseStudy.ctaLabel} <span class="btn-arrow">→</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>
    )
  }

  <!-- ========== OPPORTUNITIES ========== -->
  <section class="band cream parallax-section" id="opportunities">
    <img
      src="/assets/mark-light-gold.svg"
      alt=""
      class="parallax-mark"
      data-parallax-direction="up"
      aria-hidden="true"
    />
    <div class="wrap">
      <div class="section-head fade-up">
        <div><span class="num">{opportunities.number}</span></div>
        <div>
          <h2 style="margin-top:12px;">{opportunities.heading}</h2>
          <p style="margin-top:18px;">{opportunities.intro}</p>
        </div>
      </div>

      <div class="opportunities-grid stagger">
        {
          opportunities.criteria.map((c) => (
            <div class="opportunity">
              <span class="plus" aria-hidden="true" />
              <p>{c}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ========== OUR PEOPLE ========== -->
  <section class="band stone parallax-section" id="people">
    <img
      src="/assets/mark-light-gold.svg"
      alt=""
      class="parallax-mark subtle"
      data-parallax-direction="down"
      aria-hidden="true"
    />
    <div class="wrap">
      <div class="section-head fade-up">
        <div><span class="num">{people.number}</span></div>
        <div>
          <h2 style="margin-top:12px;">{people.heading}</h2>
          <p style="margin-top:18px;">{people.intro}</p>
        </div>
      </div>

      <div class="people-grid stagger">
        {
          directors.map((d) => (
            <article class="person">
              <div class="role" set:html={d.role} />
              <h3>{d.name}</h3>
              <p class="bio">{d.bio}</p>
              <a
                class="linkedin"
                href={d.linkedin}
                target="_blank"
                rel="noopener"
                aria-label={`${d.name} on LinkedIn`}
              >
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.063 2.063 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ========== NETWORK & PARTNERS ========== -->
  <section class="band cream" id="partners">
    <div class="wrap">
      <div class="section-head fade-up">
        <div><span class="num">{partners.number}</span></div>
        <div>
          <h2 style="margin-top:12px;">{partners.heading}</h2>
          <p style="margin-top:18px;">{partners.intro}</p>
        </div>
      </div>

      <div class="fade-up">
        <PartnersReel />
      </div>
    </div>
  </section>

  <!-- ========== CONTACT CTA ========== -->
  <ContactCTA />
</Base>
