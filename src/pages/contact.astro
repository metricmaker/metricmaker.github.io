---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import { content } from '../content';

const { contact, directors } = content;
---

<Base
  title={contact.seoTitle}
  description={contact.seoDescription}
  currentPath="/contact"
>
  <PageHeader
    eyebrow={contact.header.eyebrow}
    title={contact.header.title}
    lead={contact.header.lead}
  />

  <section class="band cream">
    <div class="wrap">
      <div class="contact-grid">
        <div>
          <h3>{contact.currentFocusHeading}</h3>
          <ul>
            {contact.currentFocus.map((x) => <li>{x}</li>)}
          </ul>

          <h3>{contact.structuresHeading}</h3>
          <ul>
            {contact.structures.map((x) => <li>{x}</li>)}
          </ul>

          <h3>{contact.responseHeading}</h3>
          <p style="color:var(--ink-mute);margin:0 0 10px;">{contact.responseBody}</p>
        </div>

        <aside style="display:flex;flex-direction:column;gap:20px;">
          {
            directors.map((d) => (
              <div class="contact-card">
                <span class="label">{d.role}</span>
                <span class="name">{d.name}</span>
                <a href={`mailto:${d.email}`}>{d.email}</a>
              </div>
            ))
          }
          <div class="contact-card" style="background:var(--navy);color:var(--paper);border-color:var(--navy);">
            <span class="label" style="color:var(--gold-soft);">General enquiries</span>
            <span class="name" style="color:var(--paper);">{contact.generalEmail}</span>
            <a
              href={`mailto:${contact.generalEmail}`}
              style="color:var(--gold-soft);border-bottom-color:rgba(255,255,255,0.2);"
            >
              {contact.generalEmail}
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Base>
