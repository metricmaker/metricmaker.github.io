---
import Base from '../layouts/Base.astro';
import StatsBand from '../components/StatsBand.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { content } from '../content';

const {
  site,
  hero,
  whatWeDo,
  approach,
  opportunities,
  people,
  directors,
  partners,
} = content;
---

<Base title={site.title} description={site.description}>
  <span id="top"></span>

  <!-- ========== HERO (full-screen drone footage) ========== -->
  <section class="hero">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster="/assets/Hitchin sketch 1.jpg"
      aria-hidden="true"
    >
      <source src="/assets/Hitchin.mp4" type="video/mp4" />
    </video>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="wrap hero-inner">
      <div>
        <h1 set:html={hero.headline} />
        <p
          class="lead"
          style="margin-top:32px;font-family:var(--serif);font-style:italic;color:var(--gold-soft);font-size:clamp(20px,1.8vw,28px);max-width:48ch;"
        >
          {hero.subheading}
        </p>
        <p class="lead">{hero.body}</p>
        <div class="actions">
          <a href="#contact" class="btn btn-primary">
            {hero.ctaPrimary} <span class="btn-arrow">→</span>
          </a>
          <a href="#what-we-do" class="btn btn-ghost-navy">{hero.ctaSecondary}</a>
        </div>
      </div>
    </div>
    <div class="hero-scroll" aria-hidden="true">
      <span>Scroll</span>
      <span class="line"></span>
    </div>
  </section>

  <!-- ========== TRACK RECORD ========== -->
  <StatsBand />

  <!-- ========== WHAT WE DO ========== -->
  <section class="band cream" id="what-we-do">
    <div class="wrap">
      <div class="section-head">
        <div><span class="num">{whatWeDo.number}</span></div>
        <div>
          <h2 style="margin-top:12px;">{whatWeDo.heading}</h2>
          <p style="margin-top:18px;">{whatWeDo.intro}</p>
        </div>
      </div>

      <div class="services-grid">
        {
          whatWeDo.services.map((s) => (
            <article class="service">
              <span class="idx">— {s.idx}</span>
              <h3 set:html={s.title.replace(
                '+',
                '<em style="color:var(--gold);font-style:normal;">+</em>',
              )} />
              <p>{s.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ========== OUR APPROACH (case study) ========== -->
  {
    approach.enabled && (
      <section class="band stone" id="approach">
        <div class="wrap">
          <div class="section-head">
            <div><span class="num">{approach.number}</span></div>
            <div>
              <h2 set:html={approach.heading} />
            </div>
          </div>

          <div class="case-study-grid">
            <div
              class="case-study-image"
              style="background-image:url('/assets/Hitchin sketch 1.jpg');"
              role="img"
              aria-label="Architectural sketch of the gardens at Priory Park Gardens, Hitchin"
            />
            <div class="case-study-copy">
              <h3>{approach.caseStudy.title}</h3>
              {approach.caseStudy.paragraphs.map((p) => <p>{p}</p>)}
              <div class="case-study-facts">
                {
                  approach.caseStudy.facts.map((f) => (
                    <div class="fact">
                      <div class="k">{f.key}</div>
                      <div class="v">{f.value}</div>
                    </div>
                  ))
                }
              </div>
              <div class="cta-row">
                <a
                  href={approach.caseStudy.ctaHref}
                  target="_blank"
                  rel="noopener"
                  class="btn btn-ghost-navy"
                >
                  {approach.caseStudy.ctaLabel} <span class="btn-arrow">→</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>
    )
  }

  <!-- ========== OPPORTUNITIES ========== -->
  <section class="band cream" id="opportunities">
    <div class="wrap">
      <div class="section-head">
        <div><span class="num">{opportunities.number}</span></div>
        <div>
          <h2 style="margin-top:12px;">{opportunities.heading}</h2>
          <p style="margin-top:18px;">{opportunities.intro}</p>
        </div>
      </div>

      <div class="opportunities-grid">
        {
          opportunities.criteria.map((c) => (
            <div class="opportunity">
              <span class="plus" aria-hidden="true" />
              <p>{c}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ========== OUR PEOPLE ========== -->
  <section class="band stone" id="people">
    <div class="wrap">
      <div class="section-head">
        <div><span class="num">{people.number}</span></div>
        <div>
          <h2 style="margin-top:12px;">{people.heading}</h2>
          <p style="margin-top:18px;">{people.intro}</p>
        </div>
      </div>

      <div class="people-grid">
        {
          directors.map((d) => (
            <article class="person">
              <div class="portrait"><span class="tag">Photo to follow</span></div>
              <div class="role">{d.role}</div>
              <h3>{d.name}</h3>
              <p class="bio">{d.bio}</p>
              <a class="email" href={`mailto:${d.email}`}>{d.email}</a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ========== NETWORK & PARTNERS ========== -->
  <section class="band cream" id="partners">
    <div class="wrap">
      <div class="section-head">
        <div><span class="num">{partners.number}</span></div>
        <div>
          <h2 style="margin-top:12px;">{partners.heading}</h2>
          <p style="margin-top:18px;">{partners.intro}</p>
        </div>
      </div>

      <div class="partners-detail">
        {
          partners.items.map((p) => (
            <article class="partner-card">
              <div class="logo">
                {p.img ? (
                  <img src={p.img} alt={p.alt ?? p.name} />
                ) : (
                  <span class="text">{p.textLogo}</span>
                )}
              </div>
              <h3>{p.name}</h3>
              <div class="eyebrow" style="color:var(--gold);">{p.role}</div>
              <p>{p.blurb}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ========== CONTACT CTA ========== -->
  <ContactCTA />
</Base>
