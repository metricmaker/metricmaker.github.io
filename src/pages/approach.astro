---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { content } from '../content';

const { approach } = content;
---

<Base
  title={approach.seoTitle}
  description={approach.seoDescription}
  currentPath="/approach"
>
  <PageHeader
    eyebrow={approach.header.eyebrow}
    title={approach.header.title}
    lead={approach.header.lead}
  />

  <!-- Large sketch image -->
  <section style="background:var(--paper);padding:0;">
    <div
      style="aspect-ratio:21/9;background:url('/assets/Hitchin sketch 1.jpg') center/cover no-repeat, var(--navy);"
      role="img"
      aria-label="Architectural watercolour sketch of Radcliffe House gardens"
    ></div>
  </section>

  <!-- Key facts band -->
  <section class="stats" style="padding:clamp(56px,7vw,90px) 0;">
    <div class="wrap">
      <div class="stats-grid" style="padding-top:0;border-top:0;grid-template-columns:repeat(4,1fr);">
        {
          approach.facts.map((f) => (
            <div class="stat">
              <div class="num" style="font-size:clamp(26px,2.5vw,34px);">{f.number}</div>
              <div class="lbl">{f.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Narrative -->
  <section class="band cream">
    <div class="wrap">
      {
        approach.narrative.map((n, i) => (
          <div class="section-head" style={i > 0 ? 'margin-top:clamp(40px,5vw,72px);' : ''}>
            <div><span class="num">{n.number}</span></div>
            <div>
              <h2>{n.heading}</h2>
              {n.paragraphs.map((p, idx) => (
                <p style={idx === 0 ? 'margin-top:18px;' : 'margin-top:10px;'}>{p}</p>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Approach principles -->
  <section class="band stone">
    <div class="wrap">
      <div class="section-head">
        <div><span class="num">How we work</span></div>
        <div><h2>{approach.principlesHeading}</h2></div>
      </div>

      <div class="services-grid">
        {
          approach.principles.map((p) => (
            <article class="service">
              <span class="idx">— {p.label}</span>
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <ContactCTA pageKey="approach" />
</Base>
