---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Pathname, e.g. "/what-we-do" — used to mark the active nav link */
  currentPath?: string;
}

const {
  title,
  description = 'Metric + Maker is an SME residential and mixed-use developer. We deliver high-quality schemes through disciplined acquisition, planning-led value creation, and hands-on delivery.',
  currentPath = '/',
} = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/assets/mark-gold.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
