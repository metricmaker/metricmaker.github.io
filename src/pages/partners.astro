---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import PartnersReel from '../components/PartnersReel.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { content } from '../content';

const { partners } = content;
---

<Base
  title={partners.seoTitle}
  description={partners.seoDescription}
  currentPath="/partners"
>
  <PageHeader
    eyebrow={partners.header.eyebrow}
    title={partners.header.title}
    lead={partners.header.lead}
  />

  <section class="band cream">
    <div class="wrap">
      <PartnersReel />

      <div class="partners-detail">
        {
          partners.items.map((p) => (
            <article class="partner-card">
              <div class="logo">
                {p.img ? (
                  <img src={p.img} alt={p.alt ?? p.name} />
                ) : (
                  <span class="text">{p.textLogo}</span>
                )}
              </div>
              <h3>{p.name}</h3>
              <div class="eyebrow" style="color:var(--gold);">{p.role}</div>
              <p>{p.blurb}</p>
            </article>
          ))
        }
      </div>

      <div style="margin-top:clamp(40px,5vw,72px);max-width:70ch;">
        <p class="lead">{partners.closingNote}</p>
      </div>
    </div>
  </section>

  <ContactCTA pageKey="partners" />
</Base>
