---
import Base from '../layouts/Base.astro';
import StatsBand from '../components/StatsBand.astro';
import PartnersReel from '../components/PartnersReel.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { content } from '../content';

const { home, site, whatWeDo, directors } = content;
---

<Base title={site.title} description={site.description} currentPath="/">
  <!-- ========== HERO (full-screen drone footage) ========== -->
  <section class="hero">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster="/assets/Hitchin sketch 1.jpg"
      aria-hidden="true"
    >
      <source src="/assets/Hitchin.mp4" type="video/mp4" />
    </video>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="wrap hero-inner">
      <div>
        <span class="eyebrow">{home.hero.eyebrow}</span>
        <h1 style="margin-top:28px;" set:html={home.hero.headline} />
        <p class="lead">{home.hero.lead}</p>
        <div class="actions">
          <a href="/contact" class="btn btn-primary">
            {home.hero.ctaPrimary} <span class="btn-arrow">→</span>
          </a>
          <a href="/what-we-do" class="btn btn-ghost-navy">{home.hero.ctaSecondary}</a>
        </div>
        <div class="meta">
          <span class="tickmark" aria-hidden="true">
            <span></span><span></span><span class="plus"></span><span></span><span></span>
          </span>
          <span>{home.hero.meta}</span>
        </div>
      </div>
    </div>
    <div class="hero-scroll" aria-hidden="true">
      <span>Scroll</span>
      <span class="line"></span>
    </div>
  </section>

  <!-- ========== STATS ========== -->
  <StatsBand />

  <!-- ========== SERVICES ========== -->
  <section class="band cream" id="what">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="num">{home.servicesSection.number}</span>
        </div>
        <div>
          <h2 style="margin-top:12px;">{home.servicesSection.heading}</h2>
          <p style="margin-top:18px;">{home.servicesSection.intro}</p>
        </div>
      </div>

      <div class="services-grid">
        {
          whatWeDo.services.map((s) => (
            <article class="service">
              <span class="idx">— {s.idx}</span>
              <h3 set:html={s.title.replace(
                '+',
                '<em style="color:var(--gold);font-style:normal;">+</em>',
              )} />
              <p>{s.summary}</p>
              <a href={`/what-we-do#${s.id}`} class="more">
                Read more
                <svg width="14" height="10" viewBox="0 0 14 10" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M1 5h12M9 1l4 4-4 4" />
                </svg>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ========== FEATURED PROJECT ========== -->
  <section class="feature" id="approach">
    <div class="feature-grid">
      <div
        class="feature-img"
        style="background-image:url('/assets/Hitchin sketch 1.jpg');"
        role="img"
        aria-label="Architectural sketch of Radcliffe House and gardens, Priory Park Gardens, Hitchin"
      ></div>
      <div class="feature-copy">
        <span class="eyebrow eyebrow-light">{home.featureProject.eyebrow}</span>
        <h2>{home.featureProject.title}</h2>
        <div class="subtitle">{home.featureProject.subtitle}</div>
        <p>{home.featureProject.body}</p>
        <div class="feature-facts">
          {
            home.featureProject.facts.map((f) => (
              <div>
                <div class="k">{f.key}</div>
                <div class="v" set:html={f.value} />
              </div>
            ))
          }
        </div>
        <div class="actions">
          <a href="/approach" class="btn btn-ghost-cream">
            {home.featureProject.ctaLabel} <span class="btn-arrow">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PEOPLE ========== -->
  <section class="band cream" id="people">
    <div class="wrap">
      <div class="section-head">
        <div><span class="num">{home.peopleSection.number}</span></div>
        <div>
          <h2 style="margin-top:12px;">{home.peopleSection.heading}</h2>
          <p style="margin-top:18px;">{home.peopleSection.intro}</p>
        </div>
      </div>

      <div class="people-grid">
        {
          directors.map((d) => (
            <article class="person">
              <div class="portrait"><span class="tag">Photo to follow</span></div>
              <div class="role">{d.role}</div>
              <h3>{d.name}</h3>
              <p class="bio">{d.shortBio}</p>
              <a class="email" href={`mailto:${d.email}`}>
                {d.email}
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ========== PARTNERS ========== -->
  <section
    class="band stone"
    id="partners"
    style="padding-top:clamp(60px,7vw,100px);padding-bottom:clamp(60px,7vw,100px);"
  >
    <div class="wrap">
      <div class="section-head" style="margin-bottom:36px;">
        <div><span class="num">{home.partnersSection.number}</span></div>
        <div>
          <h2 style="margin-top:12px;font-size:clamp(26px,3vw,40px);">{home.partnersSection.heading}</h2>
          <p style="margin-top:14px;">{home.partnersSection.intro}</p>
        </div>
      </div>
      <PartnersReel />
    </div>
  </section>

  <!-- ========== CONTACT CTA ========== -->
  <ContactCTA />
</Base>
