---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Pathname, e.g. "/what-we-do" — used to mark the active nav link */
  currentPath?: string;
}

const {
  title,
  description = 'Metric + Maker is an SME residential and mixed-use developer. We deliver high-quality schemes through disciplined acquisition, planning-led value creation, and hands-on delivery.',
  currentPath = '/',
} = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/assets/mark-gold.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    {/*
      Pre-paint script: only mark the document for animations if the
      user hasn't requested reduced motion. Doing this in <head> before
      paint avoids any flash of content.
    */}
    <script is:inline>
      (function () {
        try {
          if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
            document.documentElement.classList.add('js-anim');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Header currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer />

    {/* Scroll-driven animations: IntersectionObserver + parallax loop + number counter */}
    <script>
      // Bail entirely if user prefers reduced motion
      const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduceMotion) {
        // ---- Fade-up + staggered reveal ----
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -80px 0px' },
        );
        document
          .querySelectorAll<HTMLElement>('.fade-up, .stagger')
          .forEach((el) => observer.observe(el));

        // ---- Animated number counters (the "spin through" effect) ----
        // Parses the displayed value (e.g. "5,000" or "£1bn" or "60"),
        // resets to zero, then animates up to the target on enter view.
        const counters = document.querySelectorAll<HTMLElement>('.count[data-count-target]');
        counters.forEach((el) => {
          const target = el.dataset.countTarget || '';
          const match = target.match(/^([^\d.]*)([\d,.]+)(.*)$/);
          if (!match) return;
          const [, prefix, numText, suffix] = match;
          const hasCommas = numText.includes(',');
          const dotIndex = numText.indexOf('.');
          const naturalDecimals = dotIndex >= 0 ? numText.length - dotIndex - 1 : 0;
          const targetNum = parseFloat(numText.replace(/,/g, ''));
          if (Number.isNaN(targetNum)) return;
          // For tiny target values (e.g. "1" in "£1bn") force a decimal place
          // so the count visibly animates rather than jumping 0 → 1.
          const decimals = targetNum < 10 && naturalDecimals === 0 ? 1 : naturalDecimals;

          const format = (n: number) => {
            let s = n.toFixed(decimals);
            if (hasCommas) {
              const parts = s.split('.');
              parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ',');
              s = parts.join('.');
            }
            return prefix + s + suffix;
          };

          // Initialise displayed value at zero
          el.textContent = format(0);

          const duration = 1700;
          let startTime = 0;
          let rafId = 0;

          const tick = (now: number) => {
            if (!startTime) startTime = now;
            const t = Math.min((now - startTime) / duration, 1);
            // ease-out-cubic
            const eased = 1 - Math.pow(1 - t, 3);
            el.textContent = format(targetNum * eased);
            if (t < 1) {
              rafId = requestAnimationFrame(tick);
            } else {
              // Snap to the original display string at the end (preserves
              // exact formatting like "£1bn" rather than "£1.0bn")
              el.textContent = target;
            }
          };

          const countObserver = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (entry.isIntersecting) {
                  cancelAnimationFrame(rafId);
                  startTime = 0;
                  rafId = requestAnimationFrame(tick);
                  countObserver.unobserve(entry.target);
                }
              }
            },
            { threshold: 0.4 },
          );
          countObserver.observe(el);
        });

        // ---- Parallax brand marks ----
        const marks = document.querySelectorAll<HTMLElement>('.parallax-mark');
        if (marks.length > 0) {
          let ticking = false;
          const update = () => {
            const vh = window.innerHeight;
            for (const mark of Array.from(marks)) {
              const section = mark.closest<HTMLElement>('.parallax-section');
              if (!section) continue;
              const rect = section.getBoundingClientRect();
              const progress = (vh - rect.top) / (vh + rect.height);
              const clamped = Math.max(0, Math.min(1, progress));
              const direction = mark.dataset.parallaxDirection === 'down' ? 1 : -1;
              const range = 220;
              const offset = (clamped - 0.5) * range * direction;
              mark.style.transform = `translate3d(-50%, calc(-50% + ${offset.toFixed(1)}px), 0)`;
            }
            ticking = false;
          };
          const onScroll = () => {
            if (!ticking) {
              requestAnimationFrame(update);
              ticking = true;
            }
          };
          window.addEventListener('scroll', onScroll, { passive: true });
          window.addEventListener('resize', onScroll, { passive: true });
          update();
        }
      }
    </script>
  </body>
</html>
