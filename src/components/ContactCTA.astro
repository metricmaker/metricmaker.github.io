---
import { content } from '../content';
const cta = content.contactCta;
---

<section class="cta" id="contact">
  <div class="wrap cta-inner">
    <div class="left">
      <span class="eyebrow eyebrow-light">{cta.number}</span>
      <h2 style="margin-top:20px;" set:html={cta.heading} />
    </div>
    <div class="right">
      <p>{cta.body}</p>
      <div class="contact-block">
        {
          cta.contactLines.map((c) => (
            <a class="contact-line" href={`mailto:${c.email}`}>
              <span class="contact-label">{c.label}</span>
              <span class="contact-value">{c.email}</span>
            </a>
          ))
        }
        {
          cta.address && (
            cta.address.mapsHref ? (
              <a class="contact-line" href={cta.address.mapsHref} target="_blank" rel="noopener">
                <span class="contact-label">{cta.address.label}</span>
                <span class="contact-value">{cta.address.value}</span>
              </a>
            ) : (
              <div class="contact-line">
                <span class="contact-label">{cta.address.label}</span>
                <span class="contact-value">{cta.address.value}</span>
              </div>
            )
          )
        }
      </div>
      <div class="actions">
        <a
          href={cta.ctaHref}
          class="btn btn-primary"
          style="background:var(--gold);color:var(--navy);"
        >
          {cta.ctaLabel} <span class="btn-arrow">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
