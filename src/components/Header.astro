---
import { content } from '../content';
const { nav } = content;
---

<header class="site">
  <div class="wrap bar">
    <a href="#top" class="brand" aria-label="Metric + Maker — home">
      <img src="/assets/logo-navy.svg" alt="Metric + Maker" />
    </a>
    <nav class="primary" aria-label="Primary">
      {nav.links.map((l) => <a href={l.href}>{l.label}</a>)}
      <a href={nav.cta.href} class="nav-cta">
        {nav.cta.label} <span class="arr">→</span>
      </a>
    </nav>
    <button
      class="menu-toggle"
      id="menu-open-btn"
      aria-label="Open menu"
      aria-controls="mobile-menu"
      aria-expanded="false"
    >☰</button>
  </div>
</header>

<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <button
    class="menu-close"
    id="menu-close-btn"
    aria-label="Close menu"
  >✕</button>
  <nav class="mobile-nav" aria-label="Mobile">
    {nav.links.map((l) => <a href={l.href}>{l.label}</a>)}
    <a href={nav.cta.href} class="mobile-cta">{nav.cta.label}</a>
  </nav>
</div>
