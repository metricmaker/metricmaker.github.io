---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { content } from '../content';

const { whatWeDo } = content;
const [development, jv, land, investment] = whatWeDo.services;

// Each pillar alternates cream / stone background for rhythm.
const bands = ['cream', 'stone', 'cream', 'stone'] as const;
---

<Base
  title={whatWeDo.seoTitle}
  description={whatWeDo.seoDescription}
  currentPath="/what-we-do"
>
  <PageHeader
    eyebrow={whatWeDo.header.eyebrow}
    title={whatWeDo.header.title}
    lead={whatWeDo.header.lead}
  />

  <!-- Development + Contracting -->
  <section class={`band ${bands[0]}`} id={development.id}>
    <div class="wrap">
      <div class="section-head">
        <div><span class="num">— {development.idx}</span></div>
        <div>
          <h2 set:html={development.title.replace('+', '<em style="color:var(--gold);font-style:normal;">+</em>')} />
          <p style="margin-top:18px;">{development.summary}</p>
          <p style="margin-top:10px;">{development.detail}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Joint Ventures + Partnerships -->
  <section class={`band ${bands[1]}`} id={jv.id}>
    <div class="wrap">
      <div class="section-head">
        <div><span class="num">— {jv.idx}</span></div>
        <div>
          <h2 set:html={jv.title.replace('+', '<em style="color:var(--gold);font-style:normal;">+</em>')} />
          <p style="margin-top:18px;">{jv.summary}</p>
          <p style="margin-top:10px;">{jv.detail}</p>
          {
            jv.structures && jv.structures.length > 0 && (
              <ul style="margin-top:10px;padding-left:22px;color:var(--ink-mute);line-height:1.8;">
                {jv.structures.map((s) => <li>{s}</li>)}
              </ul>
            )
          }
        </div>
      </div>

      <!-- Sub-specialisms -->
      <div class="services-grid" style="margin-top:clamp(40px,5vw,72px);">
        {
          whatWeDo.jvSubSpecialisms.map((x) => (
            <article class="service">
              <span class="idx">{x.label}</span>
              <h3>{x.title}</h3>
              <p>{x.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Land + Site Acquisition -->
  <section class={`band ${bands[2]}`} id={land.id}>
    <div class="wrap">
      <div class="section-head">
        <div><span class="num">— {land.idx}</span></div>
        <div>
          <h2 set:html={land.title.replace('+', '<em style="color:var(--gold);font-style:normal;">+</em>')} />
          <p style="margin-top:18px;">{land.summary}</p>
          <p style="margin-top:10px;">{land.detail}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Investment + Asset Delivery -->
  <section class={`band ${bands[3]}`} id={investment.id}>
    <div class="wrap">
      <div class="section-head">
        <div><span class="num">— {investment.idx}</span></div>
        <div>
          <h2 set:html={investment.title.replace('+', '<em style="color:var(--gold);font-style:normal;">+</em>')} />
          <p style="margin-top:18px;">{investment.summary}</p>
          <p style="margin-top:10px;">{investment.detail}</p>
        </div>
      </div>
    </div>
  </section>

  <ContactCTA pageKey="whatWeDo" />
</Base>
