---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import StatsBand from '../components/StatsBand.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { content } from '../content';

const { people, directors } = content;
---

<Base
  title={people.seoTitle}
  description={people.seoDescription}
  currentPath="/people"
>
  <PageHeader
    eyebrow={people.header.eyebrow}
    title={people.header.title}
    lead={people.header.lead}
  />

  <section class="band cream">
    <div class="wrap">
      <div class="people-detail">
        {
          directors.map((d) => (
            <article class="person-detail">
              <div class="portrait">
                <span class="tag">Photo to follow</span>
              </div>
              <div>
                <span class="role">{d.role}</span>
                <h3>{d.name}</h3>
                <p class="quote">"{d.quote}"</p>
                {d.bio.map((p) => <p>{p}</p>)}
                <a class="email" href={`mailto:${d.email}`}>{d.email}</a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <StatsBand variant="people" />

  <ContactCTA pageKey="people" />
</Base>
