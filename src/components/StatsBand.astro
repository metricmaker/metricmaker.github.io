---
import { content } from '../content';
const { stats } = content;
---

<section class="stats" id="track-record">
  <div class="wrap">
    <div class="stats-head fade-up">
      <span class="eyebrow eyebrow-light">{stats.number}</span>
      <h2 style="margin-top:16px;">{stats.heading}</h2>
      <p>{stats.intro}</p>
    </div>
    <div class="stats-grid stagger">
      {
        stats.items.map((s) => (
          <div class="stat">
            <div class="num">
              <span class="count" data-count-target={s.number}>{s.number}</span>
              {s.suffix && <span style="color:var(--gold-soft)">{s.suffix}</span>}
            </div>
            {s.label && <div class="num-label">{s.label}</div>}
            {s.sub && <div class="lbl">{s.sub}</div>}
          </div>
        ))
      }
    </div>
  </div>
</section>
